[worldserver]

#
#   Announce the module when the player logs in?
#       Enable : 1
#       Disable: 0
#

Gambler.Announce = 1

#
#   How often the NPC sends passive messages in milliseconds.
#   Valid range: 60000 (1 minute) to 300000 (5 minutes).
#   Default: 60000 (1 minute)
#   Disable: 0
#

Gambler.MessageTimer = 60000

#
#   The spell cast to get the player's attention
#   Default: 44940
#   Disable: 0
#

Gambler.EmoteSpell = 0

#
#   Type of money allowed to gamble
#       Enable : 1
#       Disable: 0
#

Gambler.EnableGold = 1
Gambler.EnableSilver = 1
Gambler.EnableCopper = 1

#
#   Type of money to gamble
#       1: Copper, 2: Silver, 3: Gold
#       Default: 2
#

Gambler.MoneyType = 2

#
#   Gambling amounts the player can choose from.
#   The random win/loss rate works well, but larger amounts of gold can be abused.
#       Default: 1, 5, 10, 15, 20
#

Gambler.Amount1 = 1
Gambler.Amount2 = 5
Gambler.Amount3 = 10
Gambler.Amount4 = 15
Gambler.Amount5 = 20

#
#   Jackpot Amount
#   Only possible if a 100 is rolled while the jackpot event is active.
#       Default: 50
#

Gambler.Jackpot = 50

#
#   Random cooldown before the jackpot event becomes active in milliseconds.
#   The jackpot stays active until a player wins it.
#       Default Min: 7200000 (2 hours)
#       Default Max: 14400000 (4 hours)
#

Gambler.JackpotEvent.CooldownMin = 7200000
Gambler.JackpotEvent.CooldownMax = 14400000

#
#   How often the NPC yells that an active jackpot is still available in milliseconds.
#       Default: 300000 (5 minutes)
#

Gambler.JackpotEvent.ReminderTimer = 300000
